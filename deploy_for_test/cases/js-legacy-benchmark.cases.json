    {
      "name": "settings",
      "description": "不同计算配置开关。旧版 JS 通过过滤 items 模拟前端设置。",
      "cases": [
        {
          "name": "setting-enable-ce-1800",
          "target": 1800,
          "settings": { "allowCE": true }
        },
        {
          "name": "setting-no-trade-2500",
          "target": 2500,
          "settings": { "allowTrade": false }
        },
        {
          "name": "setting-no-material-777",
          "target": 777,
          "settings": { "allowMaterial": false }
        },
        {
          "name": "setting-enable-small-store-350",
          "target": 350,
          "settings": {
            "allowStore10": true,
            "allowStore20": true
          }
        },
        {
          "name": "setting-enable-ext25-1250",
          "target": 1250,
          "settings": { "allowExt25": true }
        },
        {
          "name": "setting-enable-orundums-1200",
          "target": 1200,
          "settings": {
            "allowOrundumsGreen": true,
            "allowOrundumsDevice": true
          }
        },
        {
          "name": "setting-no-high-store-4999",
          "target": 4999,
          "settings": {
            "allowStore2000": false,
            "allowStore5000": false
          }
        },
        {
          "name": "setting-no-low-star-350",
          "target": 350,
          "settings": {
            "allow2Star": false,
            "allow3Star": false
          }
        },
        {
          "name": "setting-no-upgrade-only-negative-1200",
          "target": -1200,
          "settings": {
            "allowUpgradeOnly0": false,
            "allowUpgradeOnly1": false,
            "allowUpgradeOnly2": false
          }
        },
        {
          "name": "setting-enable-general-upgrade-negative-2000",
          "target": -2000,
          "settings": { "allowUpgradeOnlyFor1": false }
        }
      ]
    },
    {
      "name": "limited",
      "description": "带用户限制的场景。旧版 JS 只支持 upgrade0/1/2 和 sanity 限制，不测试 trade2/3/4/5。",
      "cases": [
        {
          "name": "limit-no-sanity-2500",
          "target": 2500,
          "userLimits": { "sanityLimit": 0 }
        },
        {
          "name": "limit-sanity-25-2500",
          "target": 2500,
          "userLimits": { "sanityLimit": 25 }
        },
        {
          "name": "limit-sanity-50-3500",
          "target": 3500,
          "userLimits": { "sanityLimit": 50 }
        },
        {
          "name": "limit-sanity-100-4999",
          "target": 4999,
          "userLimits": { "sanityLimit": 100 }
        },
        {
          "name": "limit-low-upgrade-negative-1000",
          "target": -1000,
          "userLimits": {
            "upgrade0Limit": 1,
            "upgrade1Limit": 1,
            "upgrade2Limit": 1
          }
        },
        {
          "name": "limit-no-upgrade0-negative-500",
          "target": -500,
          "userLimits": { "upgrade0Limit": 0 }
        },
        {
          "name": "limit-no-upgrade1-negative-1500",
          "target": -1500,
          "userLimits": { "upgrade1Limit": 0 }
        },
        {
          "name": "limit-no-upgrade2-negative-2500",
          "target": -2500,
          "userLimits": { "upgrade2Limit": 0 }
        },
        {
          "name": "limit-low-all-limits-1847",
          "target": 1847,
          "userLimits": {
            "upgrade0Limit": 2,
            "upgrade1Limit": 2,
            "upgrade2Limit": 2,
            "sanityLimit": 50
          }
        },
        {
          "name": "limit-no-sanity-no-trade-2500",
          "target": 2500,
          "settings": { "allowTrade": false },
          "userLimits": { "sanityLimit": 0 }
        }
